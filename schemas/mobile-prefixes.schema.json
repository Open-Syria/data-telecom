{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensyria.org/schemas/data-telecom/mobile-prefixes.schema.json",
  "title": "OpenSyria Telecom Mobile Prefixes",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "prefix",
      "dialingPrefix",
      "operatorId",
      "subscriberNumberLength",
      "assignmentStatus",
      "sourceIds",
      "sourceReferences",
      "sourceStatus"
    ],
    "properties": {
      "id": { "$ref": "#/$defs/opensyriaId" },
      "prefix": { "type": "string", "pattern": "^[1-9][0-9]$" },
      "dialingPrefix": { "type": "string", "pattern": "^0[1-9][0-9]$" },
      "operatorId": { "$ref": "#/$defs/opensyriaId" },
      "subscriberNumberLength": { "type": "integer", "minimum": 1 },
      "assignmentStatus": {
        "type": "string",
        "enum": ["assigned", "reserved", "inactive", "unknown"]
      },
      "sourceIds": { "$ref": "#/$defs/sourceIds" },
      "sourceReferences": { "$ref": "#/$defs/sourceReferences" },
      "sourceStatus": { "$ref": "#/$defs/sourceStatus" },
      "notes": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "opensyriaId": {
      "type": "string",
      "pattern": "^sy-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "sourceIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "sourceReferences": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceReference" }
    },
    "sourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "accessedAt"],
      "properties": {
        "sourceId": { "type": "string", "minLength": 1 },
        "sourceRecordId": { "type": "string", "minLength": 1 },
        "sourceRecordDate": {
          "type": "string",
          "pattern": "^[0-9]{4}(?:-[0-9]{2}(?:-[0-9]{2})?)?$"
        },
        "accessedAt": { "type": "string", "format": "date-time" }
      }
    },
    "sourceStatus": {
      "type": "string",
      "enum": ["pending_release", "seed", "released", "deprecated"]
    }
  }
}
