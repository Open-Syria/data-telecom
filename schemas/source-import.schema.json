{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensyria.org/schemas/data-telecom/source-import.schema.json",
  "title": "OpenSyria Telecom Source Import Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sourceId",
    "sourceTitle",
    "sourceUrl",
    "license",
    "accessedAt",
    "status",
    "rawFiles",
    "importedFields",
    "targetFiles",
    "transforms",
    "reviewNotes"
  ],
  "properties": {
    "sourceId": { "type": "string", "minLength": 1 },
    "sourceTitle": { "type": "string", "minLength": 1 },
    "sourceUrl": { "type": "string", "format": "uri" },
    "license": { "type": "string", "minLength": 1 },
    "licenseUrl": { "type": "string", "format": "uri" },
    "accessedAt": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["planned", "imported", "reviewed", "rejected", "superseded"]
    },
    "rawFiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    },
    "importedFields": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "targetFiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "data/country-numbering-plans.json",
          "data/fixed-area-codes.json",
          "data/mobile-prefixes.json",
          "data/number-ranges.json",
          "data/operators.json",
          "data/sources.json"
        ]
      }
    },
    "transforms": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "reviewNotes": { "type": "string", "minLength": 1 }
  }
}
