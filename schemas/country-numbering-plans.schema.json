{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensyria.org/schemas/data-telecom/country-numbering-plans.schema.json",
  "title": "OpenSyria Telecom Country Numbering Plans",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "countryCode",
      "countryIso2",
      "countryIso3",
      "nationalPrefix",
      "internationalPrefix",
      "planScope",
      "sourceIds",
      "sourceReferences",
      "sourceStatus"
    ],
    "properties": {
      "id": { "$ref": "#/$defs/opensyriaId" },
      "countryCode": { "type": "string", "pattern": "^[0-9]{1,3}$" },
      "countryIso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "countryIso3": { "type": "string", "pattern": "^[A-Z]{3}$" },
      "nationalPrefix": { "type": ["string", "null"], "pattern": "^[0-9]+$" },
      "internationalPrefix": { "type": ["string", "null"], "pattern": "^[0-9]+$" },
      "planScope": { "type": "string", "enum": ["fixed_and_mobile"] },
      "sourceIds": { "$ref": "#/$defs/sourceIds" },
      "sourceReferences": { "$ref": "#/$defs/sourceReferences" },
      "sourceStatus": { "$ref": "#/$defs/sourceStatus" },
      "notes": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "opensyriaId": {
      "type": "string",
      "pattern": "^sy-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "sourceIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "sourceReferences": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceReference" }
    },
    "sourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "accessedAt"],
      "properties": {
        "sourceId": { "type": "string", "minLength": 1 },
        "sourceRecordId": { "type": "string", "minLength": 1 },
        "sourceRecordDate": {
          "type": "string",
          "pattern": "^[0-9]{4}(?:-[0-9]{2}(?:-[0-9]{2})?)?$"
        },
        "accessedAt": { "type": "string", "format": "date-time" }
      }
    },
    "sourceStatus": {
      "type": "string",
      "enum": ["pending_release", "seed", "released", "deprecated"]
    }
  }
}
